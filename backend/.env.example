# ===== Core =====
PROJECT_NAME=AI BI Platform
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ===== Security =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ===== CORS (comma-separated) =====
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Database =====
POSTGRES_USER=biuser
POSTGRES_PASSWORD=bipassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aibi
# Optional full override:
# DATABASE_URL=postgresql+psycopg2://biuser:bipassword@localhost:5432/aibi

# ===== Uploads =====
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=100
ALLOWED_EXTENSIONS=csv,xlsx,xls,json

# ===== LLM (optional - platform works without it) =====
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# ===== Streaming (real-time ingestion) =====
# Leave REDIS_URL empty to use the built-in in-memory stream backend.
# REDIS_URL=redis://localhost:6379/0
STREAM_BUFFER_FLUSH=50
STREAM_KEEPALIVE_SECONDS=15
